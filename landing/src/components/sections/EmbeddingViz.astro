---
import EmbeddingCanvas from "../ui/EmbeddingCanvas";
---

<section class="section bg-apple-bg-alt/50">
  <div class="max-w-5xl mx-auto px-6">
    <div class="text-center mb-12">
      <h2 class="fade-up text-3xl md:text-4xl lg:text-5xl font-bold text-apple-text tracking-tight">
        What does a decade of thinking look like?
      </h2>
      <p class="fade-up text-lg text-apple-text-secondary mt-4 max-w-xl mx-auto">
        Every dot is a note. Hover to explore. Notes that share meaning drift together — revealing patterns you never saw while writing them.
      </p>
    </div>

    <div class="fade-up">
      <EmbeddingCanvas client:visible />
    </div>
  </div>
</section>
