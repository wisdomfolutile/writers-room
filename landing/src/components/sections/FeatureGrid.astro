---
const features = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2Z"/><path d="m9 12 2 2 4-4"/></svg>`,
    title: "Deeper Recall",
    description: "Search 'what have I been avoiding writing about' and get an answer. Writers Room imagines the note you're looking for and then finds the real one.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 6h16M4 12h10M4 18h6"/><circle cx="19" cy="15" r="3"/><path d="m21.7 17.7-1.4-1.4"/></svg>`,
    title: "Reads Your Intent",
    description: "Type a name, it searches literally. Ask a question, it searches by meaning. You don't pick a mode. A mode picks you. Change modes if you want to.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>`,
    title: "Paste a Link. Find a Match.",
    description: "Drop in a literary magazine's submission call. It reads the page, understands what they want, and surfaces your best-fit drafts.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>`,
    title: "A Conversation with Your Past Self",
    description: "Before the results even load, you get a warm summary: 'You've been thinking about this since 2022...' with clickable links straight to the notes.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="6" cy="6" r="3"/><circle cx="18" cy="18" r="3"/><circle cx="18" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M6 9v6M18 9v6M9 6h6M9 18h6"/></svg>`,
    title: "See What You Think About",
    description: "A visual map of every note you've ever written, clustered by theme. Discover patterns in your own thinking you never noticed.",
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="6" width="20" height="12" rx="3"/><path d="M12 6V4M8 6V4M16 6V4M6 10h12M6 14h8"/></svg>`,
    title: "Your Notes Stay Yours",
    description: "Everything runs on your Mac. No cloud uploads, no accounts, no servers. Your words never leave your machine.",
  },
];
---

<section id="features" class="section bg-apple-bg-alt/50">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16">
      <h2 class="fade-up text-3xl md:text-4xl lg:text-5xl font-bold text-apple-text tracking-tight">
        Search that thinks like you do.
      </h2>
      <p class="fade-up text-lg text-apple-text-secondary mt-4 max-w-xl mx-auto">
        Six ways Writers Room goes beyond Cmd+F.
      </p>
    </div>

    <div data-feature-grid class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {features.map((feature) => (
        <div
          data-feature-card
          class="group bg-apple-card-solid/70 backdrop-blur-sm rounded-2xl p-7 border border-apple-border/30 hover:border-gold/30 hover:shadow-lg hover:shadow-gold/5 transition-all duration-300 opacity-0"
        >
          <div class="w-11 h-11 rounded-xl bg-apple-bg-alt border border-apple-border/50 flex items-center justify-center text-apple-text mb-4 group-hover:border-gold/30 transition-colors">
            <Fragment set:html={feature.icon} />
          </div>
          <h3 class="text-lg font-semibold text-apple-text mb-2">{feature.title}</h3>
          <p class="text-[15px] text-apple-text-secondary leading-relaxed">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
