---
const line1 = ["Best.", "Search.", "Ever."];
---

<section class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden bg-apple-bg">

  <div class="relative max-w-5xl mx-auto px-6 text-center pt-16 pb-6">
    <!-- Headline with word spans for stagger animation -->
    <h1
      data-hero-headline
      class="text-[3.25rem] md:text-[4.5rem] lg:text-[5.5rem] font-bold tracking-[-0.04em] leading-[1.0] text-apple-text mb-4"
    >
      {line1.map((word) => (
        <span class="word inline-block opacity-0 mr-[0.22em]">{word}</span>
      ))}
    </h1>

    <!-- Subheadline -->
    <p
      data-hero-sub
      class="opacity-0 text-lg md:text-[1.35rem] text-apple-text-secondary max-w-xl mx-auto mt-5 mb-10 leading-[1.5] font-normal"
    >
      Poems, essays, half-finished ideas, late-night thoughts.<br />
      Every idea you've ever had. Found in milliseconds.
    </p>
  </div>

  <!-- Hero screenshot -->
  <div data-hero-search class="opacity-0 max-w-2xl mx-auto px-6 mb-12">
    <img
      src="/hero-2.png"
      alt="Writers Room — search bar with On This Day"
      class="w-full rounded-2xl shadow-2xl shadow-black/20"
    />
  </div>

  <!-- CTA buttons -->
  <div data-hero-cta class="opacity-0 flex flex-col sm:flex-row items-center justify-center gap-4 pb-12">
    <a
      href="#setup"
      class="inline-flex items-center px-10 py-4 bg-apple-text text-apple-bg text-lg font-semibold rounded-full hover:bg-apple-text/85 transition-colors shadow-lg shadow-black/10"
    >
      Start Searching
    </a>
    <a
      href="#how-it-works"
      class="inline-flex items-center px-10 py-4 text-apple-text text-lg font-medium rounded-full border border-apple-text/20 hover:bg-apple-text/5 transition-colors"
    >
      See It In Action
    </a>
  </div>
</section>

<script>
  const queries = [
    "what have I written about leaving home?",
    "poems about my mother's kitchen",
    "that startup idea from last summer",
    "reflections on faith and doubt",
    "the essay about Lagos traffic",
    "notes where I mentioned Soyinka",
    "drafts about identity and belonging",
    "what was I thinking in December 2023?",
  ];

  const el = document.getElementById("hero-typewriter");
  if (el) {
    let currentIndex = 0;

    async function typeQuery(text: string) {
      if (!el) return;
      const currentText = el.textContent || "";
      for (let i = currentText.length; i >= 0; i--) {
        el.textContent = currentText.slice(0, i);
        await new Promise((r) => setTimeout(r, 20));
      }
      for (let i = 0; i <= text.length; i++) {
        el.textContent = text.slice(0, i);
        await new Promise((r) => setTimeout(r, 45));
      }
    }

    async function cycle() {
      await new Promise((r) => setTimeout(r, 3000));
      while (true) {
        currentIndex = (currentIndex + 1) % queries.length;
        await typeQuery(queries[currentIndex]);
        await new Promise((r) => setTimeout(r, 2500));
      }
    }

    cycle();
  }
</script>
