---
---

<section id="pricing" class="section bg-apple-bg-alt/50">
  <div class="max-w-5xl mx-auto px-6">
    <div class="text-center mb-16">
      <h2 class="fade-up text-3xl md:text-4xl lg:text-5xl font-bold text-apple-text tracking-tight">
        Pay once. Search forever.
      </h2>
      <p class="fade-up text-lg text-apple-text-secondary mt-4 max-w-xl mx-auto">
        No subscription. No usage limits. You bring an API key, and the AI costs you less than a coffee a year.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-6 max-w-3xl mx-auto" data-pricing>
      <!-- Free tier -->
      <div data-pricing-row class="rounded-2xl border border-apple-border/30 bg-apple-card-solid/70 backdrop-blur-sm p-8 opacity-0">
        <div class="text-sm font-semibold text-apple-text-secondary uppercase tracking-wider mb-2">Free</div>
        <div class="text-4xl font-bold text-apple-text mb-1">$0</div>
        <p class="text-sm text-apple-text-secondary mb-6">Up to 1,000 notes</p>
        <ul class="space-y-3 text-[15px] text-apple-text-secondary">
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-gold mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/></svg>
            Search works offline — no API key needed
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-gold mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/></svg>
            Semantic, keyword, and hybrid search
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-gold mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/></svg>
            AI summaries of your results
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-gold mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/></svg>
            Always one click away in your menu bar
          </li>
        </ul>
      </div>

      <!-- Pro tier -->
      <div data-pricing-row class="rounded-2xl border-2 border-gold/30 bg-apple-card-solid/70 backdrop-blur-sm p-8 relative opacity-0">
        <div class="absolute -top-3 right-6 px-3 py-0.5 bg-gold text-apple-code-bg text-xs font-semibold rounded-full">
          Recommended
        </div>
        <div class="text-sm font-semibold text-gold-text uppercase tracking-wider mb-2">Pro</div>
        <div class="text-4xl font-bold text-apple-text mb-1">
          $24.99
          <span class="text-lg font-normal text-apple-text-secondary">one-time</span>
        </div>
        <p class="text-sm text-apple-text-secondary mb-6">Unlimited notes, forever</p>
        <ul class="space-y-3 text-[15px] text-apple-text-secondary">
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-gold mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/></svg>
            Everything in Free
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-gold mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/></svg>
            <strong>Every note searchable — no limits</strong>
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-gold mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/></svg>
            Choose your AI — OpenAI, Claude, Gemini, Groq, and more
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-gold mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/></svg>
            Deeper search, URL matching, mind map
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-gold mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/></svg>
            Rediscover old notes with "On This Day"
          </li>
          <li class="flex items-start gap-2.5">
            <svg class="w-4 h-4 text-gold mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 01.143 1.052l-8 10.5a.75.75 0 01-1.127.075l-4.5-4.5a.75.75 0 011.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 011.05-.143z" clip-rule="evenodd"/></svg>
            Export your notes as Markdown or PDF
          </li>
        </ul>
      </div>
    </div>

    <!-- Cost breakdown -->
    <div class="mt-12 max-w-2xl mx-auto">
      <div class="fade-up text-center">
        <h3 class="text-lg font-semibold text-apple-text mb-6">The real cost of running it.</h3>
        <div class="grid grid-cols-3 gap-4 text-center">
          <div class="p-4 rounded-xl bg-apple-card-solid/70 border border-apple-border/30">
            <div class="text-2xl font-bold text-apple-text">$0.014</div>
            <div class="text-xs text-apple-text-secondary mt-1">per day<br/>(50 searches)</div>
          </div>
          <div class="p-4 rounded-xl bg-apple-card-solid/70 border border-apple-border/30">
            <div class="text-2xl font-bold text-apple-text">$0.43</div>
            <div class="text-xs text-apple-text-secondary mt-1">per month<br/>(heavy use)</div>
          </div>
          <div class="p-4 rounded-xl bg-apple-card-solid/70 border border-apple-border/30">
            <div class="text-2xl font-bold text-apple-text">$5.20</div>
            <div class="text-xs text-apple-text-secondary mt-1">per year<br/>(yes, really)</div>
          </div>
        </div>
        <p class="text-sm text-apple-text-secondary mt-4">
          Your API key, your bill. Most searches cost less than a thousandth of a cent.
          At heavy daily use, you'll spend less on Writers Room than on a single latte.
        </p>
      </div>
    </div>
  </div>
</section>
