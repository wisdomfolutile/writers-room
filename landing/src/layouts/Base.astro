---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Writers Room — Your Second Brain for Apple Notes",
  description = "A local semantic search companion that turns your Apple Notes into a searchable, AI-powered second brain. Find any note by meaning, not just keywords.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <script>
      import "../scripts/lenis-init";
      import "../scripts/animations";
    </script>
  </body>
</html>
