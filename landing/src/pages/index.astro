import Nav from "../components/sections/Nav.astro";
import Hero from "../components/sections/Hero.astro";
import StatBar from "../components/sections/StatBar.astro";
import HowItWorks from "../components/sections/HowItWorks.astro";
import SearchDemo from "../components/sections/SearchDemo.astro";
import BuiltFor from "../components/sections/BuiltFor.astro";
import EmbeddingViz from "../components/sections/EmbeddingViz.astro";
import FeatureGrid from "../components/sections/FeatureGrid.astro";
import SearchModes from "../components/sections/SearchModes.astro";
